# ATRBench API configuration — copy to `.env` and fill in, or `export` these
# before launching the runner / evaluator / datagen.
#
# Each provider is reached through its own key + base URL. BASE_URL defaults
# to the vendor's official endpoint (shown commented below); set it to route
# every model through a single OpenAI-compatible gateway instead. Only the
# providers whose models you actually run need to be filled in.
#
# To load this file into your shell:
#   set -a && . ./.env && set +a

# ── OpenAI · gpt-5.4 (Responses API for tools, Chat for single-shot) ──────────
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Google Gemini · gemini-3-flash-preview / gemini-3.1-pro-preview ───────────
# GEMINI_BASE_URL is the native generateContent root. The single-shot chat
# path uses GEMINI_CHAT_BASE_URL, which defaults to {GEMINI_BASE_URL}/openai
# (Google's OpenAI-compatible layer). Point both at one gateway if you use one.
GEMINI_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_CHAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ── Anthropic · claude-opus-4-7 (native /v1/messages) ─────────────────────────
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── DeepSeek · deepseek-v4-pro / deepseek-v4-flash ────────────────────────────
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── Alibaba DashScope · qwen3.6-plus ──────────────────────────────────────────
DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── MiniMax · MiniMax-M2.7 ────────────────────────────────────────────────────
MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.io/v1

# ── Optional: redirect output / few-shot artifacts ───────────────────────────
# ATR_OUTPUTS_ROOT=./outputs
